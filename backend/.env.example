# Neon Postgres (provisioned via Vercel Marketplace)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Cron secret (auto-set by Vercel)
CRON_SECRET=

# APNs push notifications (from Apple Developer Console)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.statshot.app
APNS_KEY_BASE64=

# Twilio SMS (premium tier only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
